@startuml sequence-uc3-approve
!theme plain
skinparam shadowing false

title Diagrama de Sequencia — UC3/UC4: Aprovar ou Recusar Banca

actor "Coordenador" as coordenador
participant "DecisionPage\n(Frontend)" as frontend
participant "router\n(api)" as router
participant "BancaService\n(application)" as service
participant "MongoBancaRepository\n(infrastructure)" as repo
database "MongoDB" as db
participant "petition_service" as petition
participant "email_service" as email
participant "Postfix\n(SMTP)" as smtp

' ============================================================
' CONSULTA
' ============================================================

coordenador -> frontend : Acessa link de decisao\n(/decide/{token})
activate frontend
frontend -> router : GET /banca/decide/{token}
activate router
router -> service : get_summary(token)
activate service
service -> repo : find_by_token(token)
activate repo
repo --> service : Ok(BancaRecord)
deactivate repo
service --> router : Ok(BancaSummary)
deactivate service
router --> frontend : HTTP 200 (request, ata, ppg, status)
deactivate router
frontend --> coordenador : Exibe dados do pedido
deactivate frontend

|||

' ============================================================
' FLUXO PRINCIPAL: APROVACAO
' ============================================================
== UC3: Coordenador aprova ==

coordenador -> frontend : Clica "Aprovar"\n(observacao opcional)
activate frontend
frontend -> router : POST /banca/decide/{token}/approve\n{observation?}
activate router
router -> service : approve(token, observation)
activate service

service -> repo : find_by_token(token)
activate repo
repo --> service : Ok(BancaRecord)
deactivate repo

note right of service
    Verifica status == "pending".
    Caso contrario, retorna
    BancaAlreadyDecidedError (409).
end note

' --- Commit ATOMICO antes de qualquer e-mail ---
service -> repo : update_decision(token, "approved", observation)
activate repo
repo -> db : update_one (pending -> approved)
activate db
db --> repo : OK (1 doc alterado)
deactivate db
repo --> service : Ok(None)
deactivate repo

note right of service
    Transicao pending->approved e atomica:
    sob concorrencia, so o vencedor
    dispara os e-mails (sem duplicidade).
    Documentos NAO viajam aqui — sao
    baixados/enviados pelo painel admin.
end note

' --- (1) Notifica secretaria: documentos disponiveis ---
service -> petition : build_documents_html(req, admin_link, observation)
activate petition
petition --> service : html
deactivate petition
service -> email : send_email(secretary_email, ...)
activate email
email -> smtp : SMTP send
smtp --> email : OK
email --> service : Ok(None)
deactivate email

' --- (2) Notifica orientador (nao-fatal) ---
service -> email : send_email(orientador_email, aprovacao)
activate email
email -> smtp : SMTP send
smtp --> email : OK
email --> service : Ok(None)
deactivate email

' --- (3) Solicita agendamento a gerencia (cc CPG) ---
service -> email : send_email(gerencia_email, agendamento,\ncc=cpg_alias_email)
activate email
email -> smtp : SMTP send
smtp --> email : OK
email --> service : Ok(None)
deactivate email

service --> router : Ok(BancaDecisionResponse)
deactivate service
router --> frontend : HTTP 200 {message, ata, student_name}
deactivate router
frontend --> coordenador : "Banca aprovada e\nsecretaria notificada"
deactivate frontend

' ============================================================
' FLUXO ALTERNATIVO: RECUSA (UC4)
' ============================================================
== UC4: Coordenador recusa a banca ==

coordenador -> frontend : Clica "Recusar"\n+ justificativa
activate frontend
frontend -> router : POST /banca/decide/{token}/reject\n{reason}
activate router
router -> service : reject(token, reason)
activate service
service -> repo : update_decision(token, "rejected", reason)
activate repo
repo --> service : Ok(None)
deactivate repo
service -> petition : build_rejection_subject/html(req, reason)
activate petition
petition --> service : subject, html
deactivate petition
service -> email : send_email(orientador_email, recusa)
activate email
email -> smtp : SMTP send
smtp --> email : OK
email --> service : Ok(None)
deactivate email
service --> router : Ok(BancaDecisionResponse)
deactivate service
router --> frontend : HTTP 200
deactivate router
frontend --> coordenador : "Banca rejeitada e\nsubmetente notificado"
deactivate frontend

' ============================================================
' FLUXO ALTERNATIVO: Banca ja decidida
' ============================================================
== Fluxo Alternativo: Banca ja decidida ==

coordenador -> frontend : Tenta aprovar/recusar
activate frontend
frontend -> router : POST .../approve
activate router
router -> service : approve(token)
activate service
service -> repo : find_by_token(token)
activate repo
repo --> service : Ok(BancaRecord) status != pending
deactivate repo
service --> router : Err(BancaAlreadyDecidedError)
deactivate service
router --> frontend : HTTP 409 {current_status}
deactivate router
frontend --> coordenador : "Banca ja foi avaliada"
deactivate frontend

@enduml
