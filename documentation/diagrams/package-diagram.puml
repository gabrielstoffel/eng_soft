@startuml package-diagram
!pragma layout smetana
!theme plain
skinparam packageStyle rectangle
skinparam shadowing false
skinparam linetype ortho

title Diagrama de Pacotes — SigBah!\nEstilo Arquitetural: Clean Architecture (Camadas com Inversao de Dependencia)

' ============================================================
' TOP-LEVEL SYSTEM: FRONTEND
' ============================================================
package "SigBah! Frontend" <<system>> {
    package "Pages" <<subsystem>> {
        note as NP
            NewBancaPage (.tsx)
            DecisionPage (.jsx)
            AdminLogin (.jsx)
            AdminBancaList (.jsx)
            AdminBancaDetail (.jsx)
        end note
    }
    package "Components" <<subsystem>> {
    }
    package "Auth (token)" <<subsystem>> {
    }
    note right of "SigBah! Frontend"
        React + Vite
        JavaScript + TypeScript
        SPA, rotas por PPG (/ppgfis, /ppgenfis)
    end note
}

' ============================================================
' TOP-LEVEL SYSTEM: BACKEND
' ============================================================
package "SigBah! Backend" <<system>> {

    package "api" <<subsystem>> {
        note as N1
            router.py (submissao/decisao publica)
            admin_router.py (painel, auth Bearer)
            auth_deps.py (usuario atual + PPG)
            deps.py (Injecao de Dependencia)
            Mapeamento erro -> HTTP status
        end note
    }

    package "application" <<subsystem>> {
        note as N2
            Casos de uso:
            - BancaService / AdminBancaService
            - InviteService / AuthService
            - document_service / attachment_service
            - email_service / petition_service
            - banca_validation
        end note
    }

    package "config" <<subsystem>> {
        note as NC
            ppg_profiles:
            perfil por PPG (e-mails,
            composicao, antecedencia,
            campos obrigatorios)
        end note
    }

    package "domain" <<subsystem>> {
        note as N3
            Contratos (ABCs): BancaRepository,
            UserRepository
            Modelos (Pydantic)
            Erros tipados
            SEM dependencias externas
        end note
    }

    package "infrastructure" <<subsystem>> {
        note as N4
            MongoBancaRepository
            MongoUserRepository
            Cliente SMTP / armazenamento de anexos
        end note
    }

    package "criaBancas / criaBancasEnfis" <<library>> {
        note as N5
            Geracao de documentos PDF
            por PPG (cartas-convite, atas,
            cartazes, pareceres, relatorias)
        end note
    }

    note bottom of "SigBah! Backend"
        Python 3.12 + FastAPI + Pydantic
        PyMongo + uvicorn (ASGI)
        Padrao Result (sem excecoes na borda)
    end note
}

' ============================================================
' TOP-LEVEL SYSTEM: INFRASTRUCTURE SERVICES
' ============================================================
package "Servicos de Infraestrutura" <<system>> {
    package "MongoDB" <<framework>> {
    }
    package "Postfix" <<framework>> {
    }
    package "Mailpit" <<framework>> {
    }
    note bottom of "Servicos de Infraestrutura"
        Docker Compose
        Rede isolada (bridge)
    end note
}

' ============================================================
' DEPENDENCIAS
' ============================================================

"SigBah! Frontend" ..> "api" : <<use>>\nHTTP/JSON REST

"api" ..> "application" : <<use>>
"api" ..> "domain" : <<use>>\n(modelos, erros)
"application" ..> "domain" : <<use>>
"application" ..> "config" : <<use>>\n(perfil PPG)
"infrastructure" ..> "domain" : <<import>>\n(implementa ABCs)

"application" ..> "criaBancas / criaBancasEnfis" : <<use>>\n(geracao PDF)

"infrastructure" ..> "MongoDB" : <<use>>\n(PyMongo, 27017)
"infrastructure" ..> "Postfix" : <<use>>\n(SMTP, 2525)
"Postfix" ..> "Mailpit" : <<use>>\n(relay SMTP)

@enduml
