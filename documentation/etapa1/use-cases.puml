@startuml
left to right direction
skinparam packageStyle rectangle

actor "Orientador" as orientador
actor "Coordenador" as coordenador
actor "Secretário do PPG" as secretario

rectangle "Sistema de Gestão de Bancas" {
  usecase "Formalizar Pedido\nde Banca" as UC1
  usecase "Enviar Email para\nCoordenador/Secretário\ndo PPG" as UC2
  usecase "Avaliar Banca" as UC3
  usecase "Gerar Documentos" as UC4
  usecase "Enviar Documentos" as UC11
  usecase "Enviar Documentos\nda Banca" as UC5
  usecase "Enviar Atestados" as UC6
  usecase "Pesquisar Bancas" as UC7
  usecase "Editar Documentos" as UC8
  usecase "Gerar Relatório\nde Bancas" as UC9
  usecase "Notificar Orientador" as UC10
}

orientador -- UC1
secretario -- UC7
secretario -- UC8
coordenador -- UC3
secretario -- UC9
secretario -- UC11

UC1 ..> UC2 : <<include>>
UC3 ..> UC10 : <<include>>
UC3 <.. UC4 : <<extend>>

UC5 --|> UC11
UC6 --|> UC11
@enduml
